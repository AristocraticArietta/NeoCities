{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "paths": {
      "@components/*": [
        "./src/components/*"
      ],
      "@layouts/*": [
        "./src/layouts/*"
      ],
      "@content/*": [
        "./src/content/*"
      ],
      "@assets/*": [
        "./src/assets/*"
      ],
      "@styles/*": [
        "./src/styles/*"
      ],
      "@public/*": [
        "./public/*"
      ],
      "@scripts/*": [
        "./src/scripts/*"
      ],
      "@src/*": [
        "./src/*"
      ],
      "@data/*": [
        "./src/data/*"
      ]
    },
    "strictNullChecks": true,
    "allowJs": true,
    "target": "ES6"
  }
}