---
import type { GetStaticPaths, Page } from 'astro';
import BaseHead from '@components/BaseHead.astro';
import Footer from '@components/Footer.astro';
import Navigation from '@components/Nav.astro';
import FormattedDate from '@components/FormattedDate.astro';
import { Image } from 'astro:assets';
import { SITE_TITLE } from '@src/consts';
import { type CollectionEntry, getCollection } from 'astro:content';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  // 1. Fetch all posts
  const allPosts = await getCollection('blog');
  
  // 2. Sort posts by date (newest first)
  const sortedPosts = allPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );

  // 3. Find unique tags
  const uniqueTags = [...new Set(sortedPosts.flatMap((post) => post.data.tags || []))];

  // 4. Return the paginated routes for EVERY tag
  return uniqueTags.flatMap((tag) => {
    const filteredPosts = sortedPosts.filter((post) => post.data.tags?.includes(tag));
    
    // Use the paginate helper. Pass the filtered posts and set pageSize to 10
    return paginate(filteredPosts, {
      params: { tag: tag },
      pageSize: 5,
    });
  });
};

type Props = {
  page: Page<CollectionEntry<'blog'>>;
};

// When using paginate(), the page data comes down through Astro.props.page
const { page } = Astro.props;
const { tag } = Astro.params;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <BaseHead title=`Posts tagged with "${tag}" | ${SITE_TITLE}` description=`Posts tagged with "${tag}" | ${SITE_TITLE}`/>
</head>
<body>
    <Navigation />
    <main class="tag-container">
        <h1>Posts tagged with: <span class="tag-highlight">{tag}</span></h1>
        
        {/* Render only 5 posts for the current page */}
        <ul class="post-list">
            {page.data.map((post) => (
                <li class="post-item">
                    <a href={`/blog/${post.id}/`} class="post-card">
                        <div class="post-info">
                            <h2>{post.data.title}</h2>
                            <p>{post.data.description}</p>
                            <p>Published {post.data.pubDate && <FormattedDate date={post.data.pubDate} />}</p>
                            <p>{post.data.updatedDate && <i>Updated <FormattedDate date={post.data.updatedDate}/></i>}</p>
                        </div>
                        {post.data.heroImage && post.data.heroImageAlt && <Image class="post-image" src={post.data.heroImage} alt={post.data.heroImageAlt} />}
                    </a>
                </li>
            ))}
        </ul>

        {/* Pagination Navigation Controls */}
        <nav class="pagination">
            {page.url.prev ? (
                <a href={page.url.prev} class="nav-btn">← Newer Posts</a>
            ) : (
                <span class="nav-btn disabled">← Newer Posts</span>
            )}
            
            <span class="page-count">
                Page {page.currentPage} of {page.lastPage}
            </span>

            {page.url.next ? (
                <a href={page.url.next} class="nav-btn">Older Posts →</a>
            ) : (
                <span class="nav-btn disabled">Older Posts →</span>
            )}
        </nav>
    </main>
    <Footer />
</body>
</html>

<style>
    .tag-container {
        display: flex;
        flex-direction: column;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        width: calc(100% - 2em);
    }
    .post-list {
        list-style-type: none;
        padding: 0;
        width: 100%;
    }
    .post-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin-bottom: 1em;
    }
    .post-item:last-child {
        margin-bottom: 0;
    }
    .post-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-around;
        gap: 1em;
        width: 100%;
        background-color: var(--bg-glass);
        border-radius: var(--radius-glass);
        border: var(--border-glass);
        box-shadow: var(--shadow-glass);
        box-sizing: border-box;
        padding: 1em;
        text-decoration: none;
        color: var(--text-primary);
        transition: transform 0.3s ease;
    }
    .post-card:hover {
        transform: scaleY(1.05) scaleX(1.03);
    }
    .post-info {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1em;
        width: 100%;
    }
    .post-image {
        width: 100%;
    }
    .pagination {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        width: 100%;
    }
    .page-count {
        font: 600 1em var(--font-amarante);
        border: var(--border-glass);
        padding: 0.75em;
        box-shadow: var(--shadow-glass);
        border-radius: var(--radius-glass);
    }
    .nav-btn {
        padding: 0.5em;
        background-color: var(--bg-glass);
        border-radius: var(--radius-glass);
        border: var(--border-glass);
        box-shadow: var(--shadow-glass);
        text-decoration: none;
        transition: transform 0.3s ease;
    }
    .nav-btn:hover {
        transform: scale(1.1);
    }
    .disabled {
        text-decoration: line-through;
    }
    .disabled:hover {
        transform: none;
        cursor: not-allowed;
    }
    @media (min-width: 1000px) {
        .post-card {
            flex-direction: row;
            width: calc(100% - 2em);
        }
        .post-item {
            margin-bottom: 2em;
        }
        .post-info {
            width: 40%;
        }
        .post-image {
            width: 40%;
        }
        .pagination {
            width: 50%;
        }
    }
</style>