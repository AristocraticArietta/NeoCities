---
const { videoTitle, creatorName, creatorLink, embedLink } = Astro.props;
---
<section aria-label={videoTitle} class="videoSection">
	<h3 class="videoTitle">{videoTitle}</h3>
	<h4 class="creatorName yt-link"><a href={creatorLink}>{creatorName}</a></h4>
	<iframe class="videoPlayer" width="100%" height="100%" src={embedLink} title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
    <h3 class="about">About this Video</h3>
	<div class="description">
		<slot />
	</div>
    <hr class="divider">
</section>

<style>
	.videoSection {
		display: grid;
		grid-template-columns: 1fr;
        grid-template-rows: auto;
		justify-items: center;
        align-items: center;
        gap: var(--gap-regular);
	}
    .videoPlayer {
        aspect-ratio: 560/315;
        max-width: 75%;
    }
    @media (min-width: 1000px) {
       .videoSection {
        grid-template-columns: 1.5fr 1fr;
        grid-template-rows: auto auto 2fr auto;
       }
       .videoTitle {
        grid-column: 1 / 2;
        grid-row: 1 / 2;
       }
       .creatorName {
        grid-column: 1 / 2;
        grid-row: 2 / 3;
       }
       .videoPlayer {
        grid-column: 0 / 1;
        grid-row: 3 / 4;
        max-width: 100%;
        height: auto;
       }
       .about {
        grid-column: 2 / 3;
        grid-row: 1 / 2;
       }
       .description {
        grid-column: 2 / 3;
        grid-row: 2 / 4;
       }
       .divider {
        grid-column: 1 / 3;
        grid-row: 4 / 5;
       }
    }
</style>