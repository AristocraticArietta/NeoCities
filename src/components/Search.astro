---
// src/components/Search.astro
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');

// Build a lightweight index containing only what is necessary for searching
const searchIndex = allPosts.map(post => ({
    title: post.data.title,
    description: post.data.description || '',
    date: post.data.pubDate ? new Date(post.data.pubDate).toLocaleDateString() : '',
    tags: post.data.tags || [], // Include tags as an array
    content: (post.body || '').toLowerCase(), // Lowercase for easier matching; handle undefined body
    url: `/blog/${post.id}/`
}));
---

<div x-data={`searchSystem(${JSON.stringify(searchIndex)})`} class="search-wrapper">
    <button 
    type="button"
    @click="openModal()" 
    :aria-expanded="isOpen"
    aria-controls="search-modal"
    aria-haspopup="dialog"
    class="search-trigger-btn"
    >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="search-icon" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.604 10.604Z" />
        </svg>
        <span class="sr-only">Search posts</span>
    </button>

    <div 
        id="search-modal"
        role="dialog" 
        aria-modal="true" 
        aria-labelledby="modal-title"
        x-show="isOpen" 
        x-trap.noscript="isOpen"
        @keydown.escape.window="closeModal()"
        class="search-modal-wrapper"
        x-cloak
        x-transition:enter="transition-in"
        x-transition:enter-start="transition-endpoints"
        x-transition:enter-end="transition-middlepoints"
        x-transition:leave="transition-out"
        x-transition:leave-start="transition-middlepoints"
        x-transition:leave-end="transition-endpoints"
    >
        <div class="search-backdrop" @click="closeModal()" x-show="isOpen"></div>

        <div class="search-modal-content">
            
            <h2 id="modal-title" class="sr-only">Search Blog Posts</h2>

            <div class="search-input-wrapper">
                <input 
                    x-ref="searchInput"
                    type="search" 
                    x-model="query"
                    placeholder="Search by title, description, content, tags..."
                    aria-label="Search posts"
                    class="search-input"
                />
                
                <button @click="closeModal()" type="button" class="search-close-btn" aria-label="Close search">
                    Close
                </button>
            </div>

            <div aria-live="polite" class="sr-only">
                <span x-text="announcementText"></span>
            </div>

            <div class="search-results-container">
                <template x-if="filteredPosts.length > 0">
                    <ul class="search-result-list">
                        <template x-for="(post, index) in filteredPosts" :key="index">
                            <li class="search-result-item">
                                <a :href="post.url" class="search-result-link">
                                    <h3 class="search-result-title" x-text="post.title"></h3>
                                    <p class="search-result-date" x-text="post.date"></p>
                                    <p class="search-result-desc" x-text="post.description"></p>
                                    <!-- Display Tags if they exist -->
                                    <template x-if="post.tags && post.tags.length > 0">
                                        <div class="search-result-tags">
                                            <template x-for="tag in post.tags" :key="tag">
                                                <span class="search-tag" x-text="tag"></span>
                                            </template>
                                        </div>
                                    </template>
                                </a>
                            </li>
                        </template>
                    </ul>
                </template>

                <template x-if="query.length > 0 && filteredPosts.length === 0">
                    <p class="search-empty-state">No posts match your search query.</p>
                </template>
            </div>
        </div>
    </div>
</div>
<style>
    /* --- Alpine.js & Accessibility Utilities --- */
    [x-cloak] { 
        display: none !important; 
    }

    /* --- Trigger Button --- */
    .search-trigger-btn {
        font-size: 1em;
        padding: 0.5em;
        border: none;
        border-bottom: 0.5em solid var(--accent2);
        background-color: transparent;
        color: var(--text-primary);
        cursor: pointer;
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
		z-index: 1;
		overflow: hidden;
    }

    .search-trigger-btn::before {
        content: "";
		position: absolute;
		left: 0;
		right: 0;
        top: 0;
        bottom: 0;
		background-color: var(--accent2); /* Hover color */
		z-index: -1;

        /* Shrink to the bottom line */
		transform: scaleY(0);
		/* Lock the anchor point to the bottom side */
		transform-origin: bottom center;
		
		/* Smooth scale transition */
		transition: transform 0.4s ease-out;
    }

    .search-trigger-btn:hover::before {
        /* Expand to full height */
		transform: scaleY(1);
    }
    
    .search-icon {
        padding: 0;
        font-size: 1.7em;
        width: 1em;
        height: 1em;
    }

    /* --- Alpine Transitions --- */
    .transition-in {
        transition: 400ms ease-out;
    }
    .transition-out {
        transition: 400ms ease-in;
    }
    .transition-endpoints {
        opacity: 0%;
        scale: 50%;
    }
    .transition-middlepoints {
        opacity: 100%;
        scale: 100%;
    }

    /* --- Modal Layout --- */
    .search-modal-wrapper {
        position: fixed;
        top: 0;
        right: 0;
        bottom: 0;
        left: 0;
        z-index: 50;
        overflow-y: auto;
    }

    .search-backdrop {
        position: fixed;
        top: 0;
        right: 0;
        bottom: 0;
        left: 0;
        backdrop-filter: grayscale(100%) var(--blur-small);
    }

    .search-modal-content {
        position: relative;
        max-width: 42em;
        margin: 10em auto;
        background-color: var(--bg-glass);
        backdrop-filter: var(--blur-med);
        -webkit-backdrop-filter: var(--blur-med);
        padding: 1.5em;
        border-radius: var(--radius-glass);
        box-shadow: var(--shadow-glass);
        border: var(--border-glass);
    }

    /* --- Input Controls --- */
    .search-input-wrapper {
        position: relative;
        color: var(--text-primary);
        font-weight: bolder;
        font: 1em bold var(--font-cormorant);
    }

    .search-input {
        width: 100%;
        padding: 1em;
        padding-right: 4em; /* Make room for close button */
        border: var(--border-glass);
        border-radius: var(--radius-glass);
        box-sizing: border-box;
        font: 1em var(--font-cormorant);
        background-color: var(--bg-header);
    }

    .search-close-btn {
        position: absolute;
        right: 0.75em;
        top: 0.75em;
        background: transparent;
        border: 0.25em solid transparent;
        border-radius: var(--radius-glass);
        cursor: pointer;
        font: 1em var(--font-cormorant);
        transition: 200ms ease-in-out;
    }

    .search-close-btn:hover {
        transform: scale(125%);
        border-color: var(--accent);
    }

    /* --- Results Area --- */
    .search-results-container {
        margin-top: 1rem;
        max-height: 24rem;
        overflow-y: auto;
    }

    .search-result-list {
        list-style: none;
        padding: 0.5em;
        margin: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
    }

    .search-result-item {
        margin: 0;
        width: 95%;
    }

    .search-result-link {
        display: block;
        padding: 0.75rem;
        text-decoration: none;
        border-radius: var(--radius-glass);
        background-color: var(--bg-header);
        transition: transform 0.2s, box-shadow 0.2s;
        color: inherit;
    }

    .search-result-link:hover {
        transform: scale(105%);
        box-shadow: 0 0 0.5em rgba(0, 0, 0, 0.7);
    }

    .search-result-link:focus {
        outline: 2px solid #3b82f6;
        outline-offset: 2px;
    }

    .search-result-title {
        margin: 0 0 0.25rem 0;
        font-weight: bold;
        font-size: 1.125rem;
    }

    .search-result-date {
        margin: 0 0 0.25rem 0;
        font-size: 0.875rem;
    }

    .search-result-desc {
        margin: 0;
        font-size: 0.875rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .search-result-tags {
        display: flex;
        flex-wrap: wrap;
        margin-top: 0.5rem;
        gap: 0.5rem;
        color: var(--accent);
    }
    .search-tag {
        display: inline-block;
        padding: 0.25rem 0.5rem;
        background-color: var(--accent2);
        border-radius: var(--radius-glass);
        font-size: 0.75rem;
    }
    .search-empty-state {
        padding: 1rem 0;
        text-align: center;
    }
    @media (min-width: 1000px) {
        .search-trigger-btn {
            font-size: 1.25em;
            padding: 0.5em 1em;
        }
        .search-trigger-btn svg {
            width: 1em;
            height: 1em;
        }
    }

</style>
<script>
import Alpine from "alpinejs";

interface SearchPost {
    title: string;
    description: string;
    date: string;
    content: string;
    url: string;
    tags: string[];
}


// Alpine.js initialization logic
document.addEventListener('alpine:init', () => {
    Alpine.data('searchSystem', (initialPosts: SearchPost[]) => ({
        isOpen: false,
        query: '',
        posts: initialPosts,
        announcementText: '',

        openModal() {
            this.isOpen = true;
            // Use $nextTick to guarantee the DOM elements exist before focusing
            this.$nextTick(() => {
                this.$refs.searchInput.focus();
            });
        },

        closeModal() {
            this.isOpen = false;
            this.query = '';
        },

        // Dynamic filtering property
        get filteredPosts() {
        const cleanQuery = this.query.trim().toLowerCase();
        if (!cleanQuery) return [];

        const matches = this.posts.filter((post: SearchPost) => {
            return (
                post.title.toLowerCase().includes(cleanQuery) ||
                post.description.toLowerCase().includes(cleanQuery) ||
                post.date.toLowerCase().includes(cleanQuery) ||
                post.content.includes(cleanQuery) ||
                post.tags.some(tag => tag.toLowerCase().includes(cleanQuery))
            );
        });

        // Update screen reader live region text
        this.announcementText = `${matches.length} result${matches.length === 1 ? '' : 's'} found for "${this.query}"`;
        
            return matches;
        }
    }));
});
</script>